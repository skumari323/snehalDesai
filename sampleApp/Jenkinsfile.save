pipeline {
    agent any

    environment {
        IMAGE_NAME = "sampleapp"
        IMAGE_TAG = "${BUILD_NUMBER}"
        DOCKERHUB_REPO = "your-dockerhub-username/sampleapp"
    }

    stages {

        stage('Checkout Code') {
            steps {
                git url: 'https://github.com/skumari323/snehalDesai.git',
                    branch: 'main'
            }
        }

        stage('PR Validation') {
            when {
                changeRequest()
            }
            steps {
                echo "Running PR validation..."
                sh 'npm install || true'
                sh 'npm test || true'
                sh 'npm run lint || true'
            }
        }

        stage('Build Application') {
            steps {
                echo "Building application..."
                sh 'npm install || true'
                sh 'npm run build || true'
            }
        }

        stage('Build Docker Image (Minikube)') {
            steps {
                echo "Building Docker image inside Minikube..."
                sh """
                    eval \$(minikube docker-env)
                    docker build -t $IMAGE_NAME:$IMAGE_TAG .
          
